{
  "name": "voltchain",
  "version": "1.0.0",
  "description": "AI-powered EV supply chain intelligence dashboard",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "build:frontend": "node scripts/write-frontend-config.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "load:sse": "node scripts/sse-load-test.js",
    "load:rest": "npx autocannon -c 100 -d 20 -p 10 http://localhost:3000/api/fleet/stats",
    "load:chat": "npx autocannon -c 20 -d 15 -m POST -H \"Content-Type: application/json\" -b \"{\\\"message\\\":\\\"battery status?\\\"}\" http://localhost:3000/api/analyst/chat"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "engines": {
    "node": "20.x"
  },
  "dependencies": {
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.1.9",
    "puppeteer": "^25.3.0",
    "supertest": "^7.2.2",
    "vitest": "^2.1.9"
  }
}
